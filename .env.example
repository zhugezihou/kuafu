# ═══════════════════════════════════════════════════════════════════════════════
# 夸父 (Kuafu) 环境配置模板
# ═══════════════════════════════════════════════════════════════════════════════
#
# 使用方法:
#   1. 复制为 .env:   cp .env.example .env
#   2. 填入实际值:    编辑 .env 中的配置项
#   3. 也可以运行:    python setup_wizard.py — 交互式配置向导（推荐）
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── 必填配置 ──────────────────────────────────────────────────────────────────

# DeepSeek API Key（云端模式必须）
# 注册: https://platform.deepseek.com/
# 获取方式：登录后在「账户」页面创建 API Key
# KUAFFU_API_KEY=sk-xxx...xxxx
# DEEPSEEK_API_KEY=sk-xxx...xxxx

# ── 可选配置 ──────────────────────────────────────────────────────────────────

# LLM 后端选择: "cloud"（云端 DeepSeek，默认）或 "local"（本地 Qwen3.5-9B）
# - cloud: 需要 API Key，NVIDIA GPU 不需要
# - local: 需要 NVIDIA GPU 8GB+，需要自行部署 llama-server 和模型
# KUAFFU_BACKEND=cloud

# DeepSeek API 地址（可选，通常不需要修改）
# KUAFFU_BASE_URL=https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 本地模型配置（仅 local 后端需要）──────────────────────────────────────────

# llama-server 监听地址（默认: http://localhost:8080）
# KUAFFU_LOCAL_URL=http://localhost:8080

# 本地模型名称（用于 API 调用时的 model 字段）
# KUAFFU_LOCAL_MODEL=Qwen3.5-9B-UD-Q4_K_XL.gguf

# 本地模型最大 token（默认: 4096）
# KUAFFU_LOCAL_MAX_TOKENS=4096

# ── 飞书 WebSocket 直连通道（可选）────────────────────────────────────────────
#
# 夸父通过 lark-oapi SDK 建立飞书 WebSocket 持久连接，零延迟接收消息。
# 需要在飞书开放平台创建应用: https://open.feishu.cn/app
# - 开启「接收消息」事件权限（im:message）
# - 发布应用
#
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 个人微信 Wechaty 通道（可选）──────────────────────────────────────────────
#
# 夸父通过 Wechaty + wechaty-puppet-service（iPad 协议）连接个人微信。
# 需要 Wechaty Puppet Service Token。
# 免费申请: https://wechaty.js.org/docs/puppet-services/
#
# 首次启动 Gateway 时会打印二维码，扫码登录即开始工作。
# 群聊中 @bot 即可交互。
#
# WECHAT_PUPPET_TOKEN=puppet_xxx...xxxx

# ── 记忆系统配置（可选）────────────────────────────────────────────────────────

# 记忆模式: "file"（本地 JSON 文件，默认）或 "hindsight"（云端语义搜索）
# KUAFFU_MEMORY_MODE=file

# ── 请求配置（可选）────────────────────────────────────────────────────────────

# LLM 请求超时秒数（默认: 60）
# KUAFFU_LLM_TIMEOUT=60

# 最大工具调用轮数（默认: 15）
# KUAFFU_MAX_TOOL_ROUNDS=15

# ── Gateway 配置（可选）────────────────────────────────────────────────────────

# Gateway API Key（用于 HTTP API 认证）
# KUAFFU_GATEWAY_KEY=xxx

# Gateway 监听端口（默认: 8765）
# KUAFFU_GATEWAY_PORT=8765

# ── 其他（可选）────────────────────────────────────────────────────────────────

# 日志级别: DEBUG / INFO / WARNING / ERROR（默认: INFO）
# KUAFFU_LOG_LEVEL=INFO
