# ═══════════════════════════════════════════════════════════════════════════════
# 夸父 (Kuafu) 环境配置模板
# ═══════════════════════════════════════════════════════════════════════════════
#
# 使用方法:
#   1. 复制为 .env:   cp .env.example .env
#   2. 填入实际值:    编辑 .env 中的配置项
#   3. 也可以运行:    python setup_wizard.py  — 交互式配置向导（推荐）
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── 必填配置 ──────────────────────────────────────────────────────────────────

# DeepSeek API Key（云端模式必须）
# 注册: https://platform.deepseek.com/
# 格式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KUAFFU_API_KEY=sk-your-key-here

# ── 可选配置 ──────────────────────────────────────────────────────────────────

# LLM 后端选择: "cloud"（云端 DeepSeek，默认）或 "local"（本地 Qwen3.5-9B）
# - cloud: 需要 API Key，NVIDIA GPU 不需要
# - local: 需要 NVIDIA GPU 8GB+，需要自行部署 llama-server 和模型
# KUAFFU_BACKEND=cloud

# DeepSeek API 地址（可选，通常不需要修改）
# KUAFFU_BASE_URL=https://api.deepseek.com

# ── 本地模型配置（仅 local 后端需要）──────────────────────────────────────────

# llama-server 监听地址（默认: http://localhost:8080）
# KUAFU_LOCAL_URL=http://localhost:8080

# 本地模型名称（用于 API 调用时的 model 字段）
# KUAFU_LOCAL_MODEL=Qwen3.5-9B-UD-Q4_K_XL.gguf

# 本地模型最大 token（默认: 4096）
# KUAFU_LOCAL_MAX_TOKENS=4096

# ── 记忆系统配置（可选）────────────────────────────────────────────────────────

# 记忆模式: "file"（本地 JSON 文件，默认）或 "hindsight"（云端语义搜索）
# KUAFU_MEMORY_MODE=file

# Hindsight API Key（memory_mode=hindsight 时需要）
# 注册: https://hindsight.dev
# HINDSIGHT_API_KEY=your-hindsight-api-key

# Hindsight Bank ID（memory_mode=hindsight 时需要）
# HINDSIGHT_BANK_ID=default

# ── 飞书集成配置（可选）───────────────────────────────────────────────────────

# 飞书应用 ID 和 Secret
# 创建应用: https://open.feishu.cn/app
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书聊天群 ID（接收消息的目标群）
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── 请求配置（可选）────────────────────────────────────────────────────────────

# LLM 请求超时秒数（默认: 60）
# KUAFU_LLM_TIMEOUT=60

# 最大工具调用轮数（默认: 15）
# KUAFU_MAX_TOOL_ROUNDS=15

# ── 其他（可选）────────────────────────────────────────────────────────────────

# 日志级别: DEBUG / INFO / WARNING / ERROR（默认: INFO）
# KUAFU_LOG_LEVEL=INFO

# 工作线程数（cron 调度等，默认: 4）
# KUAFU_WORKERS=4
