{
  "expo": {
    "name": "夸父",
    "slug": "kuafu-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kuafu",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zhugezihou.kuafu",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "夸父需要访问您的位置以提供定位服务",
        "NSMicrophoneUsageDescription": "夸父需要麦克风权限以支持语音输入",
        "NSSpeechRecognitionUsageDescription": "夸父需要语音识别权限以将语音转为文字",
        "NSCameraUsageDescription": "夸父需要相机权限以支持拍照和扫码",
        "NSPhotoLibraryUsageDescription": "夸父需要相册权限以支持选择照片"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1b1d1e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.zhugezihou.kuafu",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-clipboard",
      "expo-file-system",
      "expo-image-picker",
      "expo-notifications",
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "夸父需要麦克风权限以支持语音输入",
          "speechRecognitionPermission": "夸父需要语音识别权限以将语音转为文字"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4c925971-2682-40e9-bcdc-637fdd9ea14f"
      }
    }
  }
}
