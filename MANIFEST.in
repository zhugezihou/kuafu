include README.md LICENSE
include IDENTITY.md
include core/IDENTITY.md
include core/*.yaml
include experts/*.yaml
include cron/*.yaml
recursive-include core *.yaml *.md

# 排除 node_modules 和构建产物
prune kuafu-app/node_modules
prune kuafu-desktop/node_modules
prune dist
prune build
prune *.egg-info
global-exclude __pycache__
global-exclude *.pyc
global-exclude .DS_Store
